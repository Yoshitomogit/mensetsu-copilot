# Google AI Studio / Gemini API キー（サーバーと live-proxy で共有）
GEMINI_API_KEY=

# 要約 API（/api/brief）で使うモデル。gemini-2.0-flash は提供終了している場合があります。
GEMINI_BRIEF_MODEL=gemini-2.5-flash

# Live セッションで使うモデル（既定: テキスト応答向け）
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# Live: 3.1 プレビュー等「ネイティブ音声」モデルは TEXT 応答が使えず 1011 になるため、
# 既定では AUDIO + 出力文字起こしでテキスト表示する（プロキシ側）。2.0 等で TEXT 直出しだけ使う場合のみ true。
# GEMINI_LIVE_TEXT_MODALITY=true

# WebSocket プロキシのポート
LIVE_PROXY_PORT=3001

# ブラウザから接続する WebSocket URL（開発時は既定で ws://localhost:3001）
NEXT_PUBLIC_LIVE_WS_URL=ws://localhost:3001
